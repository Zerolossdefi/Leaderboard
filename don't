<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZLT Trading Competition Tier Table</title>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #050505; 
            color: #e0e0e0; 
            min-height: 100vh;
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #111; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #D4A017; }

        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        
        /* Header */
        .header { text-align: center; margin-bottom: 30px; padding-top: 20px; }
        .header-subtitle { font-size: 12px; letter-spacing: 4px; color: #D4A017; text-transform: uppercase; margin-bottom: 8px; font-weight: 700; }
        .header-title { font-size: 32px; font-weight: 800; color: #D4A017; margin: 0; letter-spacing: -0.5px; }
        .header-desc { color: #888; margin-top: 8px; font-size: 14px; }
        
        /* Stats Grid */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
        .stat-card { background: #111; border: 1px solid rgba(212, 160, 23, 0.2); border-radius: 10px; padding: 16px; transition: transform 0.2s, border-color 0.2s; }
        .stat-card:hover { transform: translateY(-2px); border-color: #D4A017; }
        .stat-label { font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
        .stat-value { font-size: 18px; font-weight: 700; color: #D4A017; }
        
        /* Controls */
        .controls { display: flex; gap: 12px; margin-bottom: 20px; align-items: center; flex-wrap: wrap; }
        .search-input { 
            background: #1a1a1a; border: 1px solid #333; border-radius: 8px; 
            color: #fff; padding: 10px 16px; font-size: 14px; width: 260px; 
            outline: none; transition: border-color 0.2s;
        }
        .search-input:focus { border-color: #D4A017; }
        .btn { 
            background: #1a1a1a; border: 1px solid #333; color: #D4A017; 
            border-radius: 6px; padding: 10px 16px; cursor: pointer; font-weight: 600; 
            font-size: 13px; transition: all 0.2s;
        }
        .btn:hover:not(:disabled) { background: #D4A017; color: #000; border-color: #D4A017; }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn-primary { background: #D4A017; color: #000; border: none; }
        .btn-primary:hover { background: #e5b120; }
        .result-count { color: #666; font-size: 13px; margin-left: auto; }
        
        /* Table */
        .table-wrapper { overflow-x: auto; border-radius: 12px; border: 1px solid #222; background: #0a0a0a; }
        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        thead { background: #D4A017; color: #000; }
        th { padding: 14px 16px; text-align: right; font-weight: 800; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; }
        th:first-child, th:nth-child(2) { text-align: left; }
        tbody tr { border-bottom: 1px solid #1a1a1a; transition: background 0.15s; }
        tbody tr:hover { background: #1a1a00; }
        tbody tr:last-child { border-bottom: none; }
        td { padding: 12px 16px; color: #ccc; text-align: right; }
        td:first-child { color: #666; font-size: 12px; text-align: left; }
        td:nth-child(2) { color: #D4A017; font-weight: 700; text-align: left; }
        
        .badge { 
            display: inline-block; padding: 4px 10px; border-radius: 4px; font-size: 11px; 
            font-weight: 700; text-align: center; min-width: 60px;
        }
        .badge-success { background: #002a1a; color: #4caf90; }
        .badge-warning { background: #3a2200; color: #ffaa00; }
        .badge-danger { background: #3a0000; color: #ff4444; }
        
        /* Pagination */
        .pagination { display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 24px; flex-wrap: wrap; }
        .page-btn { min-width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; }
        .page-btn.active { background: #D4A017; color: #000; border-color: #D4A017; font-weight: 800; }
        
        /* Legend */
        .legend { display: flex; gap: 24px; margin-top: 30px; flex-wrap: wrap; justify-content: center; padding: 20px; background: #0a0a0a; border-radius: 8px; border: 1px solid #1a1a1a; }
        .legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #888; }
        .legend-dot { width: 10px; height: 10px; border-radius: 2px; }
        
        .footer { text-align: center; color: #333; font-size: 10px; margin-top: 30px; padding-bottom: 20px; letter-spacing: 2px; text-transform: uppercase; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useMemo } = React;

        const ITEMS_PER_PAGE = 50;
        const TOTAL_ZLT_BUDGET = 3_000_000;

        function generateTiers() {
            const tiers = [];
            const volumes = [1];
            for (let v = 5; v <= 10000; v += 5) volumes.push(v);

            volumes.forEach((vol, i) => {
                const rate = parseFloat((450 * Math.pow(vol, 0.15)).toFixed(2));
                const zlt = Math.round(450 * Math.pow(vol, 1.15));
                const worthAtDollar = zlt;
                const fee = parseFloat((vol * 0.003).toFixed(3));
                tiers.push({ tier: i + 1, volume: vol, rate, zlt, worthAtDollar, fee });
            });
            return tiers;
        }

        const ALL_TIERS = generateTiers();

        function fmt(n) {
            if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(2) + "B";
            if (n >= 1_000_000) return (n / 1_000_000).toFixed(2) + "M";
            if (n >= 1_000) return (n / 1_000).toFixed(2) + "K";
            return n.toLocaleString();
        }

        function ZLTTierTable() {
            const [search, setSearch] = useState("");
            const [page, setPage] = useState(1);

            const filtered = useMemo(() => {
                if (!search) return ALL_TIERS;
                const val = parseFloat(search);
                if (isNaN(val)) return ALL_TIERS;
                return ALL_TIERS.filter(t => t.volume === val || t.tier === val);
            }, [search]);

            const totalPages = Math.ceil(filtered.length / ITEMS_PER_PAGE);
            const paginated = filtered.slice((page - 1) * ITEMS_PER_PAGE, page * ITEMS_PER_PAGE);

            // Reset to page 1 if search changes
            const handleSearch = (e) => {
                setSearch(e.target.value);
                setPage(1);
            };

            const clearSearch = () => {
                setSearch("");
                setPage(1);
            };

            return (
                <div className="container">
                    {/* Header */}
                    <div className="header">
                        <div className="header-subtitle">Zeroloss Token</div>
                        <h1 className="header-title">ZLT Trading Competition</h1>
                        <p className="header-desc">Tier Reward Table — $1 Base · 450 ZLT/$1 · 0.3% Fee</p>
                    </div>

                    {/* Stats Bar */}
                    <div className="stats-grid">
                        <div className="stat-card">
                            <div className="stat-label">Total Tiers</div>
                            <div className="stat-value">{ALL_TIERS.length.toLocaleString()}</div>
                        </div>
                        <div className="stat-card">
                            <div className="stat-label">Weekly ZLT Budget</div>
                            <div className="stat-value">3,000,000</div>
                        </div>
                        <div className="stat-card">
                            <div className="stat-label">Base Rate</div>
                            <div className="stat-value">450 ZLT / $1</div>
                        </div>
                        <div className="stat-card">
                            <div className="stat-label">Target Price</div>
                            <div className="stat-value">$1.00 / ZLT</div>
                        </div>
                    </div>

                    {/* Search */}
                    <div className="controls">
                        <input
                            type="number"
                            placeholder="Search by volume ($) or tier..."
                            value={search}
                            onChange={handleSearch}
                            className="search-input"
                        />
                        {search && (
                            <button onClick={clearSearch} className="btn btn-primary">
                                Clear
                            </button>
                        )}
                        <span className="result-count">{filtered.length} results found</span>
                    </div>

                    {/* Table */}
                    <div className="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Tier</th>
                                    <th>Volume ($)</th>
                                    <th>Rate (ZLT/$)</th>
                                    <th>ZLT Reward</th>
                                    <th>Worth @ $1</th>
                                    <th>0.3% Fee</th>
                                    <th>Budget Slots</th>
                                </tr>
                            </thead>
                            <tbody>
                                {paginated.map((t) => {
                                    const slots = Math.floor(TOTAL_ZLT_BUDGET / t.zlt);
                                    const isHighTier = t.volume >= 5000;
                                    
                                    let badgeClass = "badge-success";
                                    let badgeText = slots >= 1000 ? "1000+" : slots;
                                    
                                    if (slots === 0) {
                                        badgeClass = "badge-danger";
                                        badgeText = "Seasonal";
                                    } else if (slots < 5) {
                                        badgeClass = "badge-warning";
                                    }

                                    return (
                                        <tr key={t.tier}>
                                            <td>#{t.tier}</td>
                                            <td>${t.volume.toLocaleString()}</td>
                                            <td>{fmt(t.rate)}</td>
                                            <td style={{color: isHighTier ? "#ff9900" : "#fff", fontWeight: 600}}>{fmt(t.zlt)}</td>
                                            <td style={{color: "#4caf90"}}>${fmt(t.worthAtDollar)}</td>
                                            <td style={{color: "#9c9cff"}}>${t.fee.toFixed(3)}</td>
                                            <td>
                                                <span className={`badge ${badgeClass}`}>
                                                    {badgeText}
                                                </span>
                                            </td>
                                        </tr>
                                    );
                                })}
                            </tbody>
                        </table>
                    </div>

                    {/* Pagination */}
                    <div className="pagination">
                        <button onClick={() => setPage(1)} disabled={page === 1} className="btn page-btn">«</button>
                        <button onClick={() => setPage(p => Math.max(1, p - 1))} disabled={page === 1} className="btn">‹ Prev</button>
                        
                        {[...Array(Math.min(5, totalPages))].map((_, i) => {
                            let p;
                            if (totalPages <= 5) p = i + 1;
                            else if (page <= 3) p = i + 1;
                            else if (page >= totalPages - 2) p = totalPages - 4 + i;
                            else p = page - 2 + i;
                            
                            return (
                                <button 
                                    key={p} 
                                    onClick={() => setPage(p)} 
                                    className={`btn page-btn ${page === p ? 'active' : ''}`}
                                >
                                    {p}
                                </button>
                            );
                        })}

                        <button onClick={() => setPage(p => Math.min(totalPages, p + 1))} disabled={page === totalPages} className="btn">Next ›</button>
                        <button onClick={() => setPage(totalPages)} disabled={page === totalPages} className="btn page-btn">»</button>
                        
                        <span style={{color: "#555", fontSize: "12px", marginLeft: "10px"}}>Page {page} of {totalPages}</span>
                    </div>

                    {/* Legend */}
                    <div className="legend">
                        <div className="legend-item">
                            <div className="legend-dot" style={{background: "#4caf90"}}></div>
                            <span>Fits within 3M weekly budget</span>
                        </div>
                        <div className="legend-item">
                            <div className="legend-dot" style={{background: "#ffaa00"}}></div>
                            <span>Tight — fewer than 5 slots</span>
                        </div>
                        <div className="legend-item">
                            <div className="legend-dot" style={{background: "#ff4444"}}></div>
                            <span>Seasonal pool needed (>3M ZLT)</span>
                        </div>
                    </div>

                    <div className="footer">
                        ZEROLOSS ECOSYSTEM · ZLT TOKEN · TRADING COMPETITION FRAMEWORK
                    </div>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<ZLTTierTable />);
    </script>
</body>
</html>
